namespace com.project.customer;

entity Customer{

    @title: 'Customer Id'
    key kunnr : String(10);  
    @title: 'Customer Name'
    name1 : String(100); 
    @title: 'City'
    orto1 : String(50); 
    @title: 'Address No'
    adrnr : String(10); 
    @title: 'Phone No'
    phone : String(15); 
}
